# WDK seed phrase (BIP-39, 12 or 24 words) -- used for Spark Lightning wallet
WDK_SEED="your twenty four word seed phrase goes here"

# Dry run mode (default: true) -- set to false to pay the Lightning invoice
DRY_RUN=true

# Target Rumble user to tip
RUMBLE_USER=crypto_vib

# Tip amount in USDT (default: 1.00)
TIP_AMOUNT_USD=1.00

# Optional: expected creator address (for validation). Required when SKIP_RUMBLE=true.
EXPECTED_ADDRESS=0xf6ae15c6f613638be32f934d986b45522e3f546f

# Headless Chromium (e.g. Railway). Rumble's Cloudflare usually blocks this — use SKIP_RUMBLE.
HEADLESS=false

# Skip Rumble UI; use EXPECTED_ADDRESS only (required for server / headless)
SKIP_RUMBLE=false

# Optional: ms to wait on Cloudflare (default 120000)
# CLOUDFLARE_TIMEOUT_MS=120000
