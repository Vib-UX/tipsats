# WDK seed phrase (BIP-39, 12 or 24 words) -- used for Spark Lightning wallet
WDK_SEED="your twenty four word seed phrase goes here"

# Dry run mode (default: true) -- set to false to pay the Lightning invoice
DRY_RUN=true

# Target Rumble user to tip
RUMBLE_USER=crypto_vib

# Tip amount in USDT (default: 1.00)
TIP_AMOUNT_USD=1.00

# Optional: expected creator address (for validation)
EXPECTED_ADDRESS=0xf6ae15c6f613638be32f934d986b45522e3f546f
