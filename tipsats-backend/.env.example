# Spark wallet seed phrase (BIP-39, 12 or 24 words). Optional if you use NWC for all Lightning.
# WDK_SEED="your seed phrase here"

# Lightning backend: auto (default) = NWC when NWC_URL is set, else Spark when WDK_SEED is set.
# On Railway, prefer NWC if Spark API is blocked: set NWC_URL and omit WDK_SEED for LN, or use LIGHTNING_BACKEND=nwc.
# LIGHTNING_BACKEND=auto

# CORS: comma-separated browser origins (local Next + Vercel, etc.)
CORS_ORIGIN=http://localhost:3000,https://tipsats.vercel.app

# Run Playwright in headless mode (true for server deployment)
HEADLESS=false

# Harness: skip Rumble (Cloudflare) and use EXPECTED_ADDRESS in pipeline. Default: true when HEADLESS=true
# SKIP_RUMBLE=true

# When SKIP_RUMBLE=false, defaults to true: search demo (Bitcoin Ben → Simply Bitcoin). Set false for legacy /user flow.
# RUMBLE_SEARCH_DEMO=true

# Port for the Express server
PORT=8080

# Nostr Wallet Connect (NIP-47) — same connection string as Alby / other NWC apps.
# Used for: funding invoices (make_invoice), paying Boltz invoices (pay_invoice), wallet balance — when LIGHTNING_BACKEND is nwc or auto with NWC_URL set.
# `secret=` (64 hex) signs kind-1 notes when NOSTR_PRIVATE_KEY is unset.
# NWC_URL=nostr+walletconnect://<wallet_pubkey>?relay=wss%3A%2F%2F...&secret=<64_hex>

# Nostr kind-1: set NOSTR_PRIVATE_KEY (hex/nsec) and/or NWC_URL above — either can sign
# WebSocket path: same signed event to each relay; success if any relay returns OK.
# Default relays if unset: wss://relay.damus.io,wss://nos.lol
# NOSTR_RELAY_URLS=wss://relay.damus.io,wss://nos.lol
# NOSTR_RELAY_URL=wss://relay.damus.io   # single relay (ignored if NOSTR_RELAY_URLS is set)
# Optional: http-nostr — if set, POST /publish is used instead (uses NOSTR_RELAY_URL or first relay).
# HTTP_NOSTR_BASE_URL=https://your-http-nostr.example.com
# NOSTR_NOTE_URL_TEMPLATE=https://njump.me/{eventId}

# ERC-4337 Polygon (agent USDT custody + batch payouts)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
PIMLICO_API_KEY=your_pimlico_api_key_here
