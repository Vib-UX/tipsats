# Spark wallet seed phrase (BIP-39, 12 or 24 words)
WDK_SEED="your seed phrase here"

# CORS: comma-separated browser origins (local Next + Vercel, etc.)
CORS_ORIGIN=http://localhost:3000,https://tipsats.vercel.app

# Run Playwright in headless mode (true for server deployment)
HEADLESS=false

# Harness: skip Rumble (Cloudflare) and use EXPECTED_ADDRESS in pipeline. Default: true when HEADLESS=true
# SKIP_RUMBLE=true

# Port for the Express server
PORT=8080
